# =============================================================================
# Production (Vercel) — required for correct SEO
# =============================================================================
# Must match your live site exactly: https + your primary host (no trailing slash).
# Wrong value breaks canonical URLs, sitemap.xml, and robots.txt.
NEXT_PUBLIC_SITE_URL=https://monemone.vercel.app

# =============================================================================
# Google Search Console (optional if you use the HTML file in /public)
# =============================================================================
# GOOGLE_SITE_VERIFICATION=your_token_here

# =============================================================================
# Google Analytics 4  →  add in Vercel → Settings → Environment Variables → Production
# =============================================================================
# After saving, trigger a new deployment so the script loads on the live site.
# Find ID: GA4 → Admin → Data streams → your Web stream → Measurement ID (G-XXXXXXXXXX).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# =============================================================================
# Public contact email  →  same Vercel env UI (shows on /contact, no code change later)
# =============================================================================
NEXT_PUBLIC_CONTACT_EMAIL=

# =============================================================================
# Google AdSense (after AdSense approves the site — apply in the AdSense console first)
# =============================================================================
# Then create ad units, copy ca-pub-… and slot IDs here, redeploy. Leave empty until then.
# Publisher ID: ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_CLIENT=
# Create display ad units in AdSense and paste slot IDs. If you only have one unit,
# set NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT and omit the rest.
NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT=
NEXT_PUBLIC_ADSENSE_SLOT_INTRO=
NEXT_PUBLIC_ADSENSE_SLOT_MID=
NEXT_PUBLIC_ADSENSE_SLOT_PRE_FAQ=
NEXT_PUBLIC_ADSENSE_SLOT_HOME=

# =============================================================================
# Affiliate URLs (optional — paste your referral links in Vercel when you have them)
# =============================================================================
# If unset, the site uses official brand homepages as fallbacks.
# NEXT_PUBLIC_AFFILIATE_HONEYGAIN_URL=https://...
# NEXT_PUBLIC_AFFILIATE_SWAGBUCKS_URL=https://...
# NEXT_PUBLIC_AFFILIATE_YSENSE_URL=https://...
# NEXT_PUBLIC_AFFILIATE_INBOXDOLLARS_URL=https://...
# NEXT_PUBLIC_AFFILIATE_TOLUNA_URL=https://...
# NEXT_PUBLIC_AFFILIATE_GAMEE_URL=https://...
