# Public site URL (no trailing slash). Set in Vercel → Project → Settings → Environment Variables.
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Optional: Google Search Console meta verification (content token from GSC). File method uses public/google*.html instead.
# GOOGLE_SITE_VERIFICATION=your_token_here

# Optional: replace with your full affiliate/referral URLs (any query string is preserved; UTM tags are appended if missing).
# If unset, the site uses official brand URLs as fallbacks.
# NEXT_PUBLIC_AFFILIATE_HONEYGAIN_URL=https://...
# NEXT_PUBLIC_AFFILIATE_SWAGBUCKS_URL=https://...
# NEXT_PUBLIC_AFFILIATE_YSENSE_URL=https://...
# NEXT_PUBLIC_AFFILIATE_INBOXDOLLARS_URL=https://...
# NEXT_PUBLIC_AFFILIATE_TOLUNA_URL=https://...
# NEXT_PUBLIC_AFFILIATE_GAMEE_URL=https://...
